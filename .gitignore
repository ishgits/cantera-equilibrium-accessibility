# macOS metadata
.DS_Store
__MACOSX/
._*

# Python caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Jupyter checkpoints
.ipynb_checkpoints/

# Editor / assistant session config
.claude/

# Optional local environments
.venv/
venv/
.env

# Local scratch/logs
*.log
tmp_compare_*/

# Internal release-planning notes (not part of the public package)
release_planning/

# Generated workflow outputs
figures/**/*.png
figures/**/*.pdf
figures/**/*.svg
models/single_product/**/*.yaml
models/single_product/*.csv
data/raw/*.csv
data/processed/*.csv
data/results/*.csv
data/results/*.md

# Note: example/template inputs under inputs/ are intentionally tracked.

# Generated sensitivity-study outputs. Each study's study_config.yaml (the only
# file users edit) and the whole studies/_template/ directory stay tracked; all
# generated artifacts below are regenerated by the scripts and are not committed.
studies/**/design_matrix.csv
studies/**/generated_scenarios.yaml
studies/**/*_manifest.csv
studies/**/thermo_offsets.csv
studies/**/run_provenance.json
studies/**/models/
studies/**/processed/
studies/**/results/
studies/**/figures/

# The amino-acid scan scaffold is fully machine-generated and transient
# (regenerate with scripts/new_amino_acid_batch.py); it is not committed.
studies/amino_acid_scan/

# Curated / published study outputs are intentionally versioned. The generic
# studies/** rules above would otherwise ignore their generated artifacts, so
# each published study is re-included explicitly:
!studies/alanine_mvp/
!studies/alanine_mvp/**
!studies/aa_nh3/
!studies/aa_nh3/**
!studies/aa_no_nh3/
!studies/aa_no_nh3/**
!studies/_paper_extension/
!studies/_paper_extension/**
!studies/_nh3_combined/
!studies/_nh3_combined/**

# Keep clean directory scaffolds
!.gitkeep
